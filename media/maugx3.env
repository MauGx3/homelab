# General UID/GIU and Timezone
TZ=America/Sao_Paulo
PUID=1000
PGID=100

# Input your VPN provider and type here
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=openvpn

# Mandatory, airvpn forwarded port
FIREWALL_VPN_INPUT_PORTS=8388

# Copy all these varibles from your generated configuration file
OPENVPN_CUSTOM_CONFIG=/gluetun/hotspotshield.ovpn
OPENVPN_USER=ROI2T5J6IZC5QKN6T4DYZLMFHBIFKJUU
OPENVPN_PASSWORD=

# Optional location variables, comma seperated list,no spaces after commas, make sure it matches the config you created
SERVER_COUNTRIES=Brazil
SERVER_CITIES=Sao_Paulo

# Heath check duration
HEALTH_VPN_DURATION_INITIAL=120s
